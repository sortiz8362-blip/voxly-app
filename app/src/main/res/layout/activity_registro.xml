<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="30dp">

            <TextView
                android:id="@+id/tvAtras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Atrás"
                android:textColor="#1DA1F2"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="5dp"/>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvPasoIndicador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paso 1 de 4"
                android:textColor="#888888"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPaso1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crea tu cuenta"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="Nombre completo"
                android:padding="15dp"
                android:layout_marginBottom="15dp"/>

            <EditText
                android:id="@+id/etFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="Fecha de nacimiento ▼"
                android:focusable="false"
                android:cursorVisible="false"
                android:padding="15dp"
                android:layout_marginBottom="15dp"/>

            <EditText
                android:id="@+id/etGenero"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="Género ▼"
                android:focusable="false"
                android:cursorVisible="false"
                android:padding="15dp"
                android:layout_marginBottom="25dp"/>

            <Button
                android:id="@+id/btnSiguiente1"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000"
                android:text="Siguiente"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPaso2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿De dónde eres?"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etPais"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="País ▼"
                android:focusable="false"
                android:cursorVisible="false"
                android:padding="15dp"
                android:layout_marginBottom="15dp"/>

            <EditText
                android:id="@+id/etEstado"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="Estado o Provincia (Opcional)"
                android:padding="15dp"
                android:layout_marginBottom="25dp"/>

            <Button
                android:id="@+id/btnSiguiente2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000"
                android:text="Siguiente"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPaso3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tus credenciales de acceso"
                android:textColor="#888888"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo electrónico"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="ejemplo@gmail.com"
                android:inputType="textEmailAddress"
                android:padding="15dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código de verificación"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/etCodigoVerificacion"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:background="#15202B"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#AAB8C2"
                    android:hint="123456"
                    android:inputType="number"
                    android:maxLength="6"
                    android:letterSpacing="0.3"
                    android:padding="15dp"
                    android:layout_marginEnd="10dp"/>

                <Button
                    android:id="@+id/btnEnviarCodigo"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:backgroundTint="#1DA1F2"
                    android:textColor="#FFFFFF"
                    android:text="Enviar código"
                    android:textAllCaps="false"
                    android:textStyle="bold"/>
            </LinearLayout>

            <CheckBox
                android:id="@+id/cbTerminos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Acepto los Términos y Condiciones y la Política de Privacidad"
                android:textColor="#888888"
                android:buttonTint="#1DA1F2"
                android:layout_marginBottom="25dp"/>

            <Button
                android:id="@+id/btnSiguiente3"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000"
                android:text="Siguiente"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPaso4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Elige tu identidad"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="Nombre de usuario (Ej: sortiz)"
                android:padding="15dp"
                android:layout_marginBottom="15dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#15202B"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB8C2"
                android:hint="Crea una contraseña"
                android:inputType="textPassword"
                android:padding="15dp"
                android:layout_marginBottom="25dp"/>

            <Button
                android:id="@+id/btnFinalizar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#1DA1F2"
                android:textColor="#FFFFFF"
                android:text="Finalizar y crear cuenta"
                android:textStyle="bold"
                android:textAllCaps="false"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>